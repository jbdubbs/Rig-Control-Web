{
  "name": "rigcontrol-web",
  "private": true,
  "version": "04.14.2026-Beta1",
  "author": "Jason Weisberger NT0Y",
  "description": "A web-based frontend for hamlib rigctld for local installation and portable backend capabilities.",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build --outDir dist",
    "start": "node server.ts",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-electron build",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "electron:dev": "ELECTRON_RUN=true electron -r tsx electron/main.ts",
    "electron:build": "npm run build && npm run build:electron && electron-builder",
    "build:electron": "esbuild electron/main.ts --bundle --platform=node --outfile=dist-electron/main.cjs --external:electron --external:vite && esbuild electron/preload.ts --bundle --platform=node --outfile=dist-electron/preload.cjs --external:electron",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.rigcontrol.web",
    "productName": "RIGCONTROL WEB",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "radios.json"
    ],
    "asarUnpack": [
      "bin/**/*",
      "**/*.node",
      "**/node_modules/libopus-node/**/*.wasm"
    ],
    "win": {
      "target": "nsis",
      "files": [
        "bin/windows/**/*"
      ]
    },
    "linux": {
      "target": "AppImage",
      "files": [
        "bin/linux/**/*"
      ]
    },
    "mac": {
      "target": "dmg",
      "files": [
        "bin/mac/**/*"
      ]
    }
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "libopus-node": "^0.0.4",
    "lucide-react": "^0.546.0",
    "lyra-codec": "^1.1.1",
    "motion": "^12.23.24",
    "naudiodon": "github:jbdubbs/naudiodon-gcc15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitest/ui": "^4.1.2",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2",
    "wait-on": "^9.0.4"
  }
}
